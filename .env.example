APP_ENV=local
OFFLINE_MODE=true
SERVICE_NAME=meeting-intelligence-api
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
CHROMA_PATH=./chroma
CHROMA_COLLECTION=meeting_memory
LOG_LEVEL=INFO
MAX_TRANSCRIPT_CHARS_FOR_DIRECT_SUMMARY=16000
CHUNK_MAX_CHARS=1200
CHUNK_OVERLAP_CHARS=160
MEETINGBANK_URL=
DATA_DIR=data
DATABASE_URL=
JWT_SECRET=
JWT_ISSUER=meeting-intelligence
JWT_EXPIRATION_MINUTES=60
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
